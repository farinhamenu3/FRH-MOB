	HeadOption.Font = Enum.Font.GothamSemibold
	HeadOption.TextSize = 10
	HeadOption.Parent = OptionsContainer
	HeadOption.ZIndex = 3

	local TorsoOption = Instance.new("TextButton")
	TorsoOption.Size = UDim2.new(1, 0, 0, 25)
	TorsoOption.Position = UDim2.new(0, 0, 0, 25)
	TorsoOption.BackgroundColor3 = Color3.fromRGB(45, 35, 55)
	TorsoOption.Text = "PEITO"
	TorsoOption.TextColor3 = Color3.fromRGB(180, 180, 180)
	TorsoOption.Font = Enum.Font.GothamSemibold
	TorsoOption.TextSize = 10
	TorsoOption.Parent = OptionsContainer
	TorsoOption.ZIndex = 3

	local PelvisOption = Instance.new("TextButton")
	PelvisOption.Size = UDim2.new(1, 0, 0, 25)
	PelvisOption.Position = UDim2.new(0, 0, 0, 50)
	PelvisOption.BackgroundColor3 = Color3.fromRGB(45, 35, 55)
	PelvisOption.Text = "CINTURA"
	PelvisOption.TextColor3 = Color3.fromRGB(180, 180, 180)
	PelvisOption.Font = Enum.Font.GothamSemibold
	PelvisOption.TextSize = 10
	PelvisOption.Parent = OptionsContainer
	PelvisOption.ZIndex = 3

	local isOpen = false

	local function updateSelection(option)
		CheatSettings.AimbotTarget = option
		
		local displayNames = {
			Head = "CABEÇA",
			Torso = "PEITO",
			Pelvis = "CINTURA"
		}
		DropdownBtn.Text = "🎯 " .. displayNames[option]
		
		local options = {
			{btn = HeadOption, key = "Head"},
			{btn = TorsoOption, key = "Torso"},
			{btn = PelvisOption, key = "Pelvis"}
		}
		
		for _, item in pairs(options) do
			if item.key == option then
				item.btn.BackgroundColor3 = Color3.fromRGB(168, 85, 247)
				item.btn.TextColor3 = Color3.fromRGB(255, 255, 255)
			else
				item.btn.BackgroundColor3 = Color3.fromRGB(45, 35, 55)
				item.btn.TextColor3 = Color3.fromRGB(180, 180, 180)
			end
		end
		
		print("Alvo do Aimbot alterado para:", option)
	end

	DropdownBtn.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		OptionsContainer.Visible = isOpen
		DropdownIcon.Text = isOpen and "▲" or "▼"
		
		if isOpen then
			OptionsContainer.ZIndex = 10
			for _, child in pairs(OptionsContainer:GetDescendants()) do
				if child:IsA("TextButton") or child:IsA("Frame") then
					child.ZIndex = 10
				end
			end
		end
	end)

	HeadOption.MouseButton1Click:Connect(function()
		updateSelection("Head")
		isOpen = false
		OptionsContainer.Visible = false
		DropdownIcon.Text = "▼"
	end)

	TorsoOption.MouseButton1Click:Connect(function()
		updateSelection("Torso")
		isOpen = false
		OptionsContainer.Visible = false
		DropdownIcon.Text = "▼"
	end)

	PelvisOption.MouseButton1Click:Connect(function()
		updateSelection("Pelvis")
		isOpen = false
		OptionsContainer.Visible = false
		DropdownIcon.Text = "▼"
	end)

	UserInputService.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and isOpen then
			task.wait(0.1)
			local mousePos = UserInputService:GetMouseLocation()
			local absPos = OptionsContainer.AbsolutePosition
			local absSize = OptionsContainer.AbsoluteSize
			local btnAbsPos = DropdownBtn.AbsolutePosition
			local btnAbsSize = DropdownBtn.AbsoluteSize
			
			local clickedInside = (mousePos.X >= absPos.X and mousePos.X <= absPos.X + absSize.X and
								  mousePos.Y >= absPos.Y and mousePos.Y <= absPos.Y + absSize.Y)
			local clickedOnButton = (mousePos.X >= btnAbsPos.X and mousePos.X <= btnAbsPos.X + btnAbsSize.X and
									mousePos.Y >= btnAbsPos.Y and mousePos.Y <= btnAbsPos.Y + btnAbsSize.Y)
			
			if not clickedInside and not clickedOnButton then
				isOpen = false
				OptionsContainer.Visible = false
				DropdownIcon.Text = "▼"
			end
		end
	end)

	updateSelection("Head")
	return MainRow
end

