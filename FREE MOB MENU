-- =============================================================================
-- DRAG DO BOTÃO FLUTUANTE (SIMPLIFICADO)
-- =============================================================================
local dragging = false
local dragStartPos = nil
local startPos = nil

FloatButton.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStartPos = input.Position
		startPos = FloatButton.Position
	end
end)

FloatButton.InputChanged:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if dragging and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
		local delta = input.Position - dragStartPos
		
		-- Só move se tiver arrastado mais de 20 pixels
		if delta.Magnitude > 20 then
			local newPos = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
			
			-- Limita o botão dentro da tela
			local maxX = 1 - (FloatButton.Size.X.Scale + 0.05)
			local maxY = 1 - (FloatButton.Size.Y.Scale + 0.05)
			
			newPos = UDim2.new(
				math.clamp(newPos.X.Scale, 0, maxX),
				math.clamp(newPos.X.Offset, 0, 0),
				math.clamp(newPos.Y.Scale, 0, maxY),
				math.clamp(newPos.Y.Offset, 0, 0)
			)
			
			FloatButton.Position = newPos
		end
	end
end)

FloatButton.InputEnded:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

