local function ToggleMenu()
	print("ToggleMenu chamado!") -- Debug
	CheatSettings.MenuVisible = not CheatSettings.MenuVisible
	
	if CheatSettings.MenuVisible then
		MainFrame.Visible = true
		local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		local goal = {Position = UDim2.new(0.5, -350, 0.5, -270)}
		local tween = TweenService:Create(MainFrame, tweenInfo, goal)
		tween:Play()
		ButtonText.Text = "MENU"
		print("Menu ABERTO")
	else
		local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
		local goal = {Position = UDim2.new(0.5, -350, 0.5, -270, true)}
		local tween = TweenService:Create(MainFrame, tweenInfo, goal)
		tween:Play()
		tween.Completed:Connect(function()
			MainFrame.Visible = false
		end)
		ButtonText.Text = "MENU"
		print("Menu FECHADO")
	end
end

